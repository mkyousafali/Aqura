# Environment Variables for Aqura Management System

# === Supabase Configuration ===
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# === App Configuration ===
VITE_APP_NAME=Aqura
VITE_APP_VERSION=1.0.0
VITE_APP_DOMAIN=aqura.app
NODE_ENV=development

# === Backend Configuration ===
BACKEND_URL=http://localhost:8080
GO_ENV=development
PORT=8080

# === Security (CHANGE IN PRODUCTION) ===
JWT_SECRET=your_jwt_secret_here_change_in_production
ENCRYPTION_KEY=your_encryption_key_here_change_in_production

# === Bootstrap Admin (SECURE AND CHANGE IMMEDIATELY) ===
BOOTSTRAP_USERNAME=masteradmin
BOOTSTRAP_PASSWORD=Aquraadmin

# === Database ===
DATABASE_URL=postgresql://postgres:password@localhost:5432/aqura

# === Storage ===
SUPABASE_STORAGE_BUCKET=aqura-files

# === PWA Configuration ===
VITE_PWA_SHORT_NAME=Aqura
VITE_PWA_DESCRIPTION=Aqura Management System
VITE_PWA_THEME_COLOR=#f08300
VITE_PWA_BACKGROUND_COLOR=#ffffff

# === i18n Configuration ===
VITE_DEFAULT_LOCALE=en
VITE_SUPPORTED_LOCALES=en,ar

# === Windows Installer ===
WINDOWS_APP_ID=com.aqura.app
WINDOWS_PUBLISHER=Aqura Inc
WINDOWS_PUBLISHER_DISPLAY_NAME=Aqura Inc
