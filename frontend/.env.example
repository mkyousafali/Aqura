# ============================================
# Supabase Configuration
# ============================================
VITE_SUPABASE_URL=https://supabase.urbanaqura.com
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# PostgreSQL Database Connection (for server-side)
# ============================================
DATABASE_URL=postgres://supabase_admin:password@host:5432/postgres

# ============================================
# JWT Secret
# ============================================
JWT_SECRET=your-jwt-secret-key

# ============================================
# Third-party APIs
# ============================================
REMOVE_BG_API_KEY=your-remove-bg-api-key
PIXABAY_API_KEY=your-pixabay-api-key
GOOGLE_API_KEY=your-google-api-key
GOOGLE_SEARCH_ENGINE_ID=your-google-search-engine-id
VITE_GOOGLE_API_KEY=your-google-api-key
VITE_GOOGLE_SEARCH_ENGINE_ID=your-google-search-engine-id
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_TTS_API_KEY=your-google-tts-api-key
VITE_GOOGLE_VISION_API_KEY=your-google-vision-api-key

# ============================================
# Web Push Notifications
# ============================================
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ============================================
# Facebook Meta
# ============================================
FACEBOOK_TOKEN=your-facebook-token

# ============================================
# Google Cloud Service Account (Vertex AI - Veo, Imagen, Gemini, TTS)
# CRITICAL: Must be set on Vercel for AI Marketing features to work
# ============================================
GOOGLE_PROJECT_ID=your-google-project-id
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_LOCATION=europe-west4

# ============================================
# Notes for Deployment to Vercel
# ============================================
# 1. All GOOGLE_* variables are REQUIRED for AI image/video generation
# 2. GOOGLE_PRIVATE_KEY must have escaped newlines: use \n not actual line breaks
# 3. In Vercel dashboard: Project Settings > Environment Variables
# 4. Add each GOOGLE_* variable individually
# 5. For GOOGLE_PRIVATE_KEY, copy the entire key including BEGIN/END lines
# 6. Make sure to mark sensitive variables (marked with "Sensitive" in Vercel)
